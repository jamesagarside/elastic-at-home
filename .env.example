# Ingress Mode - controls how services are accessed:
# - "selfsigned": Self-signed certs with hostname routing via port 443 (default)
# - "letsencrypt": Let's Encrypt certs with hostname routing via port 443
# - "direct": Self-signed certs with port-based routing (IP access, no DNS needed)
#             Access via: https://<host-ip>:5601 (Kibana), :9200 (ES), :8220 (Fleet)
INGRESS_MODE=selfsigned

# LetsEncrypt ACME Email (only required if INGRESS_MODE=letsencrypt)
ACME_EMAIL=your-email@example.com

# Cloudflare API Token (only required if INGRESS_MODE=letsencrypt)
# Generate here: https://dash.cloudflare.com/profile/api-tokens
CF_DNS_API_TOKEN=

# Password for the 'elastic' user (at least 6 characters)
ELASTIC_PASSWORD=changeme

# Password for the 'kibana_system' user (at least 6 characters)
KIBANA_PASSWORD=changeme

# Secret Token APM Agents use for connecting to APM Server
APM_SECRET_TOKEN=changeme

# Version of Elastic products
STACK_VERSION=9.3.2

# Set the cluster name
CLUSTER_NAME=elastic-at-home

# Elastic Stack Hostnames
# For letsencrypt mode: Use your public domain names
# For selfsigned mode: Use your local domain names
# For direct mode: Use unique local names (e.g., kibana.local, es.local, fleet.local)
#                  DO NOT use "localhost" for all - must be unique to avoid duplicate extra_hosts
KIBANA_DOMAIN_NAME=kibana.siem.<cloudflare-domain>
ES_DOMAIN_NAME=elasticsearch.siem.<cloudflare-domain>
FLEET_DOMAIN_NAME=fleet.siem.<cloudflare-domain>
APM_DOMAIN_NAME=apm.siem.<cloudflare-domain>
AGENT_DOMAIN_NAME=agent.siem.<cloudflare-domain>

# Traefik Dashboard Hostname
TRAEFIK_DOMAIN_NAME=proxy.siem.<cloudflare-domain>

# Traefik Host IP (used as SAN in certificates for direct mode)
# Leave empty to default to 127.0.0.1
TRAEFIK_IP=

# External ports for Fleet configuration
# These define how external agents connect to your stack through Traefik.
# For selfsigned/letsencrypt modes: use 443 (standard HTTPS via Traefik)
# For direct mode: use the service-specific ports (9200, 8220, 8200)
EXTERNAL_ES_PORT=443
EXTERNAL_FLEET_PORT=443
EXTERNAL_APM_PORT=443

# Kibana public base URL (auto-derived from KIBANA_DOMAIN_NAME if not set)
# For direct mode, override with: https://<host-ip>:5601
#SERVER_PUBLICBASEURL=https://<host-ip>:5601

# Set to 'basic' or 'trial' to automatically start the 30-day trial
LICENSE=basic
#LICENSE=trial

# Allowed source IPs for TCP syslog (CIDR notation, comma-separated for multiple)
# Examples: 192.168.1.0/24, 10.0.0.1/32, 192.168.1.100/32
ALLOWED_SYSLOG_IPS=192.168.1.0/24

# Increase or decrease based on the available host memory (in bytes)
KB_MEM_LIMIT=1073741824    # 1GB
ES_MEM_LIMIT=8589934592    # 8GB
FLEET_MEM_LIMIT=1073741824 # 1GB
AGENT_MEM_LIMIT=1073741824 # 1GB

# Kibana Encryption Keys (generate your own for production use)
KB_SECURITY_ENCRYPTIONKEY=fRDzAmciu0Sv3c0S8lKxJMrxJbEoEKG1
KB_REPORTING_ENCRYPTIONKEY=Ih2qXq9iuXdiXg1jo4yXZV8gJWc6stzH
KB_OBJECTS_ENCRYPTIONKEY=ny6tYXoI3lYrRcpgMSMQAkrSBen8dE9K
